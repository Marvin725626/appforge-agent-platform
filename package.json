{
  "name": "appforge-agent-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Build, test, and iterate React/Vite applications with AI agents.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:harness && npm run build:api && npm run build:web",
    "build:shared": "npm run build:protocol && npm run build:workspace && npm run build:agent-core",
    "build:protocol": "npm run build --workspace @appforge/protocol",
    "build:workspace": "npm run build --workspace @appforge/workspace",
    "build:agent-core": "npm run build --workspace @appforge/agent-core",
    "build:api": "npm run build --workspace @appforge/api",
    "build:harness": "npm run build --workspace @appforge/harness",
    "build:web": "npm run build --workspace @appforge/web",
    "dev:api": "npm run dev --workspace @appforge/api",
    "dev:web": "npm run dev --workspace @appforge/web",
    "presmoke:image": "node scripts/check-node-version.mjs",
    "presmoke:llm": "node scripts/check-node-version.mjs",
    "presmoke:multi-agent": "node scripts/check-node-version.mjs",
    "presmoke:multi-agent-image": "node scripts/check-node-version.mjs",
    "smoke:agent-loop": "npm run smoke:loop --workspace @appforge/agent-core",
    "smoke:image": "npm run smoke:image --workspace @appforge/api",
    "smoke:llm": "npm run smoke:real --workspace @appforge/agent-core",
    "smoke:multi-agent": "npm run smoke:multi-agent --workspace @appforge/api",
    "smoke:parallel-coding": "npm run smoke:parallel-coding --workspace @appforge/api",
    "smoke:parallel-run": "npm run smoke:parallel-run --workspace @appforge/api",
    "smoke:multi-agent-image": "npm run smoke:multi-agent-image --workspace @appforge/api",
    "smoke:react-app": "npm run smoke:react-app --workspace @appforge/agent-core",
    "smoke:template": "npm run smoke:template --workspace @appforge/workspace",
    "check:encoding": "node scripts/check-encoding.mjs",
    "start:api": "npm run start --workspace @appforge/api",
    "pretest": "npm run build:shared && npm run build:harness",
    "test": "npm run test --workspaces --if-present",
    "pretypecheck": "npm run build:shared && npm run build:harness",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.8",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
