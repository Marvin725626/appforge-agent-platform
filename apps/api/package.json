{
  "name": "@appforge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "node ../../scripts/check-node-version.mjs",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "pretest": "node ../../scripts/check-node-version.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "pretypecheck": "node ../../scripts/check-node-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@appforge/agent-core": "0.1.0",
    "@appforge/harness": "0.1.0",
    "@appforge/protocol": "0.1.0",
    "@appforge/workspace": "0.1.0",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.0.0"
  }
}
