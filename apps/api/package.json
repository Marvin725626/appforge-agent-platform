{
  "name": "@appforge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "node ../../scripts/check-node-version.mjs",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "presmoke:image": "node ../../scripts/check-node-version.mjs",
    "smoke:image": "tsx --env-file=../../.env src/real-image-provider-smoke.ts",
    "presmoke:multi-agent": "node ../../scripts/check-node-version.mjs",
    "smoke:multi-agent": "tsx --env-file=../../.env src/real-multi-agent-smoke.ts",
    "presmoke:parallel-coding": "node ../../scripts/check-node-version.mjs",
    "smoke:parallel-coding": "tsx --env-file=../../.env src/real-parallel-coding-smoke.ts",
    "presmoke:parallel-run": "node ../../scripts/check-node-version.mjs",
    "smoke:parallel-run": "tsx --env-file=../../.env src/real-parallel-run-smoke.ts",
    "presmoke:multi-agent-image": "node ../../scripts/check-node-version.mjs",
    "smoke:multi-agent-image": "tsx --env-file=../../.env src/real-multi-agent-image-smoke.ts",
    "benchmark:focused-edit": "tsx src/focused-edit-benchmark.ts",
    "pretest": "node ../../scripts/check-node-version.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "pretypecheck": "node ../../scripts/check-node-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "benchmark:design": "tsx src/design-quality-benchmark.ts --strict",
    "benchmark:design:ai": "tsx --env-file=../../.env src/design-quality-benchmark.ts --ai"
  },
  "dependencies": {
    "@appforge/agent-core": "0.1.0",
    "@appforge/harness": "0.1.0",
    "@appforge/protocol": "0.1.0",
    "@appforge/workspace": "0.1.0",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.0.0"
  }
}
