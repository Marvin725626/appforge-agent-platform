{
  "name": "@appforge/workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "node ../../scripts/check-node-version.mjs",
    "smoke:template": "tsx src/template-smoke.ts",
    "pretest": "node ../../scripts/check-node-version.mjs",
    "test": "vitest run",
    "pretypecheck": "node ../../scripts/check-node-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
